{
  "openapi": "3.1.0",
  "jsonSchemaDialect": "https://json-schema.org/draft/2020-12/schema",
  "info": {
    "title": "Companion Context Protocol Care Facility Pickup Verification HTTP Adapter",
    "version": "0.1.0-draft",
    "summary": "Illustrative OpenAPI surface for CCP Care Facility Pickup Verification.",
    "description": "This OpenAPI document is an adapter sketch. JSON Schema remains the canonical CCP contract. HTTP implementations are CCP-compatible only when they preserve the same authorization, minimization, provenance, visibility, service-window, facility-boundary, pickup-actor, and omission semantics defined by SPEC.md.",
    "license": {
      "name": "Apache-2.0",
      "url": "https://www.apache.org/licenses/LICENSE-2.0.html"
    },
    "contact": {
      "name": "Companion Context Protocol maintainers; see MAINTAINERS.md"
    }
  },
  "servers": [
    {
      "url": "https://example.com/ccp/v0",
      "description": "Illustrative server URL. Implementations should publish their own base URL."
    }
  ],
  "tags": [
    {
      "name": "Care Facility Pickup Verification",
      "description": "Purpose-bound pickup verification requests for one pet, facility, service window, and pickup actor."
    }
  ],
  "paths": {
    "/care-facility-pickup-verification": {
      "post": {
        "tags": [
          "Care Facility Pickup Verification"
        ],
        "operationId": "requestCareFacilityPickupVerification",
        "summary": "Verify pickup authorization for one actor",
        "description": "Evaluates requester identity, pet identity, facility identity, service identity, service window, pickup actor identity, requested scopes, declared purpose, active grant, visibility classes, and freshness. Protocol-level denials return a CCP response envelope with `status: denied`; malformed requests and transport authentication failures use ordinary HTTP errors.",
        "security": [
          {
            "bearerAuth": []
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/CCPVersion"
          },
          {
            "$ref": "#/components/parameters/CCPProfile"
          },
          {
            "$ref": "#/components/parameters/RequestId"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "../schemas/ccp-core.schema.json#/$defs/CareFacilityPickupVerificationRequest"
              },
              "examples": {
                "pickup_verification_request": {
                  "summary": "Care facility pickup verification request",
                  "externalValue": "../examples/care-facility-pickup-verification-request.json"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "CCP authorization result. The body may be `ok`, `partial`, or `denied` according to the canonical pickup verification response schema.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../schemas/ccp-core.schema.json#/$defs/CareFacilityPickupVerificationResponse"
                },
                "examples": {
                  "ok_response": {
                    "summary": "Allowed pickup verification response",
                    "externalValue": "../examples/care-facility-pickup-verification-response.json"
                  },
                  "owner_confirmation_required_partial_response": {
                    "summary": "Partial response requiring owner confirmation",
                    "externalValue": "../examples/care-facility-pickup-verification-owner-confirmation-response.json"
                  },
                  "facility_mismatch_denied_response": {
                    "summary": "Denied response for facility mismatch",
                    "externalValue": "../examples/care-facility-pickup-verification-facility-mismatch-denied-response.json"
                  },
                  "inactive_service_window_denied_response": {
                    "summary": "Denied response for inactive service window",
                    "externalValue": "../examples/care-facility-pickup-verification-inactive-service-window-denied-response.json"
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "415": {
            "$ref": "#/components/responses/UnsupportedMediaType"
          },
          "429": {
            "$ref": "#/components/responses/RateLimited"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          },
          "502": {
            "$ref": "#/components/responses/BadGateway"
          },
          "503": {
            "$ref": "#/components/responses/ServiceUnavailable"
          }
        },
        "x-ccp-profile": "care-facility-pickup-verification",
        "x-ccp-version": "0.1.0-draft",
        "x-ccp-canonical-request-schema": "../schemas/care-facility-pickup-verification-request.schema.json",
        "x-ccp-canonical-response-schema": "../schemas/care-facility-pickup-verification-response.schema.json"
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Illustrative transport authentication. CCP does not define an authentication mechanism."
      }
    },
    "parameters": {
      "CCPVersion": {
        "name": "CCP-Version",
        "in": "header",
        "required": false,
        "description": "Requested CCP draft version. Implementations should document supported versions.",
        "schema": {
          "type": "string",
          "example": "0.1.0-draft"
        }
      },
      "CCPProfile": {
        "name": "CCP-Profile",
        "in": "header",
        "required": false,
        "description": "Requested CCP profile.",
        "schema": {
          "type": "string",
          "enum": [
            "care-facility-pickup-verification"
          ]
        }
      },
      "RequestId": {
        "name": "X-Request-Id",
        "in": "header",
        "required": false,
        "description": "Transport-level request correlation identifier.",
        "schema": {
          "type": "string"
        }
      }
    },
    "schemas": {
      "ProblemDetails": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "type": {
            "type": "string",
            "format": "uri-reference"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "integer",
            "minimum": 100,
            "maximum": 599
          },
          "detail": {
            "type": "string"
          },
          "instance": {
            "type": "string",
            "format": "uri-reference"
          }
        }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "Malformed HTTP request or request body that cannot be parsed or validated."
      },
      "Unauthorized": {
        "description": "Missing or invalid transport authentication."
      },
      "UnsupportedMediaType": {
        "description": "Request media type is not supported. Use `application/json`."
      },
      "RateLimited": {
        "description": "Request was rate limited by the HTTP implementation."
      },
      "InternalServerError": {
        "description": "Unexpected implementation error. The response is transport-level and does not replace CCP authorization decisions.",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ProblemDetails"
            }
          }
        }
      },
      "BadGateway": {
        "description": "An upstream dependency returned an invalid response before a CCP decision could be produced.",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ProblemDetails"
            }
          }
        }
      },
      "ServiceUnavailable": {
        "description": "The implementation or an upstream dependency is temporarily unavailable before a CCP decision could be produced.",
        "content": {
          "application/problem+json": {
            "schema": {
              "$ref": "#/components/schemas/ProblemDetails"
            }
          }
        }
      }
    }
  }
}
