{
  "adapter": "mcp",
  "status": "draft",
  "ccp_version": "0.1.0-draft",
  "profile": "care-facility-context",
  "description": "Illustrative MCP tool sketches for the CCP Care Facility Context Profile. JSON Schema remains the canonical CCP contract.",
  "canonical_contract": "../schemas/ccp-core.schema.json",
  "tools": [
    {
      "name": "ccp_care_facility_context_request",
      "title": "Request CCP Care Facility Context",
      "description": "Request boarding-preparation context for one pet. The server evaluates requester identity, pet identity, facility identity, service window, scopes, purpose, active grant, visibility classes, and freshness. Protocol-level denials return a CCP response envelope with status `denied`.",
      "inputSchema": {
        "$ref": "../schemas/ccp-core.schema.json#/$defs/CareFacilityContextRequest"
      },
      "outputSchema": {
        "$ref": "../schemas/ccp-core.schema.json#/$defs/CareFacilityContextResponse"
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": false,
        "openWorldHint": true
      },
      "x-ccp-canonical-request-schema": "../schemas/care-facility-context-request.schema.json",
      "x-ccp-canonical-response-schema": "../schemas/care-facility-context-response.schema.json",
      "examples": {
        "input": "../examples/care-facility-boarding-preparation-request.json",
        "partial_output": "../examples/care-facility-boarding-preparation-response.json",
        "facility_mismatch_denied_output": "../examples/care-facility-facility-mismatch-denied-response.json",
        "expired_service_window_denied_output": "../examples/care-facility-expired-service-window-denied-response.json"
      }
    },
    {
      "name": "ccp_permission_grant_get",
      "title": "Get CCP Permission Grant",
      "description": "Fetch a permission grant visible to the requester. This is an optional MCP adapter surface requiring `pet.permission_grants.read`; grant management semantics remain implementation-specific in this draft.",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "grant_id"
        ],
        "properties": {
          "grant_id": {
            "type": "string",
            "description": "Permission grant identifier."
          }
        }
      },
      "outputSchema": {
        "$ref": "../schemas/ccp-core.schema.json#/$defs/PermissionGrant"
      },
      "annotations": {
        "readOnlyHint": true,
        "destructiveHint": false,
        "idempotentHint": true,
        "openWorldHint": false
      },
      "x-ccp-required-scope": "pet.permission_grants.read",
      "x-ccp-canonical-response-schema": "../schemas/permission-grant.schema.json",
      "examples": {
        "output": "../examples/permission-grant-care-facility-boarding-preparation.json"
      }
    }
  ]
}
